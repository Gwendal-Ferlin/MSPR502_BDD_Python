# Copier ce fichier en .env et renseigner les valeurs.
# Ne pas versionner le fichier .env (ajouter .env au .gitignore).
#
# --- Génération des secrets (copier la sortie dans la variable, sans guillemets) ---
# JWT_SECRET — signer les JWT (HS256) :
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openssl rand -hex 64
#
# DATA_ENCRYPTION_KEY — clé Fernet (chiffrement au repos ; incompatible avec les seeds santé déjà chiffrés si tu changes la clé après coup) :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Mots de passe PostgreSQL — secrets pour les bases (même logique ; pas des « tokens » API) :
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
#
# HF_API_TOKEN — pas de commande locale : créer un token sur Hugging Face puis coller la valeur hf_...
#   https://huggingface.co/settings/tokens

# PostgreSQL – Microservice Utilisateur (port 5432, base utilisateur_db)
POSTGRES_UTILISATEUR_USER=utilisateur_user
POSTGRES_UTILISATEUR_PASSWORD=

# PostgreSQL – Microservice Santé (port 5433, base sante_db)
POSTGRES_SANTE_USER=sante_user
POSTGRES_SANTE_PASSWORD=

# PostgreSQL – Microservice Gamification (port 5434, base gamification_db)
POSTGRES_GAMIFICATION_USER=gamification_user
POSTGRES_GAMIFICATION_PASSWORD=

# MongoDB (mongodb-logs sur 27017, mongodb-reco sur 27018) n'utilise pas
# de variables d'authentification dans ce Compose en dev.

# JWT (auth API) — génération : voir bloc « Génération des secrets » en haut du fichier
JWT_SECRET=

# Chiffrement au repos (Fernet) : email, hash mot de passe, profil santé, suivi biométrique, ref_restriction
# Clé ci-dessous = jeu de données init/postgres-sante/02_seed.sql (ref/profil/suivi). Sans elle, ces seeds ne se déchiffrent pas.
# En prod : générer une autre clé et réinjecter des données chiffrées (ou laisser vide + pas de seeds chiffrés).
# Génération : bloc « Génération des secrets » en haut (python cryptography.fernet)
# Si vide : API en mode legacy (pas de chiffrement à l’écriture ; déchiffrement échouera sur les seeds Fernet du 02_seed).
DATA_ENCRYPTION_KEY=Teb9fyXE4L28LXo5pC5JGRESG-aTXb6TJ1IxkfdQOQM=

# Hugging Face (optionnel) — pour POST /api/ia/recommandations (script ia-reco distant)
# Pas de CLI : créer un token Read sur HF — bloc « Génération des secrets » en haut (lien)
# HF_API_TOKEN=
# HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
# HF_TIMEOUT_SEC=12

# Optionnel : pour l'API en local, les défauts (localhost, ports ci-dessus) suffisent.
# En Docker, le compose surcharge les HOST/PORT pour pointer vers les services.

# Backup → Google Drive (optionnel) : config via Docker (mapper le port OAuth)
#   docker run -it --rm -p 53682:53682 -v "${PWD}/rclone:/config" rclone/rclone config
# → fichier local rclone/rclone/rclone.conf (ne pas commiter)
# RCLONE_REMOTE=gdrive
# RCLONE_PATH=MSPR502/backups
