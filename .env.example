# Copier ce fichier en .env et renseigner les valeurs.
# Ne pas versionner le fichier .env (ajouter .env au .gitignore).

# PostgreSQL – Microservice Utilisateur (port 5432, base utilisateur_db)
POSTGRES_UTILISATEUR_USER=utilisateur_user
POSTGRES_UTILISATEUR_PASSWORD=

# PostgreSQL – Microservice Santé (port 5433, base sante_db)
POSTGRES_SANTE_USER=sante_user
POSTGRES_SANTE_PASSWORD=

# PostgreSQL – Microservice Gamification (port 5434, base gamification_db)
POSTGRES_GAMIFICATION_USER=gamification_user
POSTGRES_GAMIFICATION_PASSWORD=

# MongoDB (mongodb-logs sur 27017, mongodb-reco sur 27018) n'utilise pas
# de variables d'authentification dans ce Compose en dev.

# JWT (auth API) – à définir en production, ne pas commiter la valeur réelle
JWT_SECRET=

# Chiffrement au repos (Fernet) : email, hash mot de passe, profil santé, suivi biométrique, ref_restriction
# Générer une clé : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Si vide : données en clair en base (comportement historique).
# DATA_ENCRYPTION_KEY=

# Hugging Face (optionnel) — pour POST /api/ia/recommandations (script ia-reco distant)
# Obtenir un token : https://huggingface.co/settings/tokens
# HF_API_TOKEN=
# HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
# HF_TIMEOUT_SEC=12

# RGPD — effacement définitif après N jours en suppression logique (script scripts/purge_comptes_rgpd.py)
# RGPD_SOFT_DELETE_RETENTION_DAYS=730

# Optionnel : pour l'API en local, les défauts (localhost, ports ci-dessus) suffisent.
# En Docker, le compose surcharge les HOST/PORT pour pointer vers les services.

# Backup → Google Drive (optionnel) : config via Docker (mapper le port OAuth)
#   docker run -it --rm -p 53682:53682 -v "${PWD}/rclone:/config" rclone/rclone config
# → fichier local rclone/rclone/rclone.conf (ne pas commiter)
# RCLONE_REMOTE=gdrive
# RCLONE_PATH=MSPR502/backups
